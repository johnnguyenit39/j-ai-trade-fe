# Copy to .env and fill in real values. Do NOT commit .env.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# AI agent API token. Currently a DeepSeek key (format: sk-...).
VITE_AI_AGENT_TOKEN_KEY="your-api-key-here"

# Active provider: deepseek | openai | claude
VITE_AI_PROVIDER="deepseek"

# Risk-based lot sizing for the trade card (optional; defaults shown).
# Account equity in USDT and % risked per trade (0.5 = 0.5%). Set account to 0
# to disable sizing and show the LLM's raw lot instead.
VITE_ADVISOR_ACCOUNT_USDT="1000"
VITE_ADVISOR_RISK_PCT="0.5"

# Firebase web config — Console → Project settings → Your apps → Web app.
# Public-by-design (NOT the service account). Leave blank to run without
# persistence (chat history stays in memory only).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
